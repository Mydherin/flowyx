# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=flowyx
POSTGRES_USER=flowyx
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ─── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=flowyx-videos

# ─── Spring Boot backend ──────────────────────────────────────
# DB_URL uses "postgres" as hostname (Docker service name)
DB_URL=jdbc:postgresql://postgres:5432/flowyx
DB_USERNAME=flowyx
DB_PASSWORD=CHANGE_ME_strong_password
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_minio_password
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
CORS_ALLOWED_ORIGINS=https://flowyx.skypea.dev

# ─── Frontend build arg (baked into image by Vite at build time) ──
# Must match GOOGLE_CLIENT_ID above — same credential, two consumers.
# VITE_API_BASE_URL is intentionally NOT set → defaults to '' in code
# so all API calls use relative paths and nginx proxies them.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
